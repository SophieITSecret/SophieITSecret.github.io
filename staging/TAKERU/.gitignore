# 画像データは原則無視（バックアップ・一時ファイルなど。例: editor/image_backup/）
*.png
*.jpg
*.gif

# ただし images/ 内のカード画像はGit管理対象（GitHub Pagesで配信するため）
!images/*.png
!images/*.jpg
!images/*.gif

# PWAアイコンは例外（Git管理対象）
!icon-192.png
!icon-512.png
!takeru-touch-icon.png

# 音声データを無視（一時・バックアップのみ）
*.wav
*.m4a

# voices/ 内のMP3はGit管理対象（GitHub Pagesで配信するため）
# ただし voices_backup/ は除外
voices_backup/

# 一時WAVファイル（OS tmpdir配下のため通常不要だが念のため）
voices_temp/

# Python キャッシュ
__pycache__/
*.pyc
